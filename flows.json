        "func": "// Aseguramos que el mensaje sea un objeto manipulable\nlet payload = typeof msg.payload === 'string' ? JSON.parse(msg.payload) : msg.payload;\n\n// Extraemos los valores (si no vienen, ponemos 0)\nlet temp = payload.temperatura || 0;\nlet hum = payload.humedad || 0;\nlet ruido = payload.ruido || 0;\n\n// Preparamos la consulta SQL\nmsg.topic = `INSERT INTO mediciones (temperatura, humedad, ruido) VALUES (${temp}, ${hum}, ${ruido})`;\n\nreturn msg;",
