        "type": "function",
        "z": "f62a74adbda426b9",
        "name": "temp",
        "func": "let data = [];\n\n// Extraer solo la temperatura\nmsg.payload.forEach(row => {\n    let time = new Date(row.timestamp + \"Z\").getTime();\n    if (row.temperatura !== null && row.temperatura !== undefined) {\n        data.push({x: time, y: row.temperatura});\n    }\n});\n\nmsg.payload = [{\n    \"series\": [\"Temperatura\"],\n    \"data\": [data],\n    \"labels\": [\"Temperatura\"]\n}];\n\nreturn msg;",
