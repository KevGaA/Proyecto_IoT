        "func": "// Aseguramos que el payload sea un objeto manipulable\nlet data = typeof msg.payload === 'string' ? JSON.parse(msg.payload) : msg.payload;\n\n// --- 1. CONFIGURACIÓN DE UMBRALES ---\n// Define aquí qué consideras un dato \"crítico\"\nconst UMBRAL_TEMP = 30.0;     // Alerta si supera los 30°C\nconst UMBRAL_RUIDO = 1500;    // Alerta si el ruido supera 1500\nconst UMBRAL_DISTANCIA = 50;  // Alerta si hay un objeto/persona a menos de 80cm\n\n// --- 2. CONFIGURACIÓN ANTI-SPAM (COOLDOWN) ---\n// Define el tiempo de silencio obligatorio entre alertas del mismo tipo\nconst TIEMPO_ESPERA = 60000; // 60,000 milisegundos = 1 minuto entero\nconst miChatId = \"1007849868\"; // REEMPLAZA CON TU CHAT ID DE TELEGRAM\n\n// Recuperamos la memoria del nodo para saber cuándo fue la última alerta\n// Si es la primera vez que se ejecuta, iniciamos los tiempos en 0\nlet ultimaAlerta = context.get('ultimaAlerta') || {\n    temp: 0,\n    ruido: 0,\n    movimiento: 0\n};\n\nlet ahora = Date.now();\nlet alertasActivas = [];\n\n// --- 3. EVALUACIÓN DE REGLAS ---\n\n// Regla 1: Temperatura\nif (data.temperatura && data.temperatura > UMBRAL_TEMP) {\n    if (ahora - ultimaAlerta.temp > TIEMPO_ESPERA) {\n        alertasActivas.push(\"🔥 ALERTA: Temperatura crítica detectada (\" + data.temperatura + \"°C)\");\n        ultimaAlerta.temp = ahora; // Guardamos la hora de esta alerta\n    }\n}\n\n// Regla 2: Ruido\nif (data.ruido && data.ruido > UMBRAL_RUIDO) {\n    if (ahora - ultimaAlerta.ruido > TIEMPO_ESPERA) {\n        alertasActivas.push(\"🔊 ALERTA: Fuerte ruido detectado (\" + data.ruido + \")\");\n        ultimaAlerta.ruido = ahora;\n    }\n}\n\n// Regla 3: Intrusión (Distancia)\nif (data.distancia && data.distancia > 0 && data.distancia < UMBRAL_DISTANCIA) {\n    if (ahora - ultimaAlerta.movimiento > TIEMPO_ESPERA) {\n        alertasActivas.push(\"🚶 ALERTA: Posible intruso a \" + data.distancia + \" cm\");\n        ultimaAlerta.movimiento = ahora;\n    }\n}\n\n// --- 4. GUARDAR MEMORIA Y ENVIAR ---\n\n// Guardamos los tiempos actualizados en la memoria interna del nodo\ncontext.set('ultimaAlerta', ultimaAlerta);\n\n// Si se rompió algún umbral y pasó el tiempo de espera, enviamos el mensaje\nif (alertasActivas.length > 0) {\n\n    // 1. Preparamos el mensaje con el formato exacto para Telegram\n    let msgTelegram = {\n        payload: {\n            chatId: miChatId,\n            type: \"message\",\n            content: \"⚠️ *REPORTE DE EVENTOS:*\\n\\n\" + alertasActivas.join(\"\\n\")\n        }\n    };\n\n    // 2. Preparamos un mensaje de texto simple para el Dashboard\n    let msgDashboard = {\n        payload: alertasActivas.join(\" | \") // Usamos \" | \" para separar múltiples alertas en una misma línea\n    };\n\n    // Retornamos un arreglo: El primer elemento va por la Salida 1 (Telegram)\n    // El segundo elemento va por la Salida 2 (Dashboard)\n    return [msgTelegram, msgDashboard];\n\n} else {\n    // Si no hay alertas nuevas, no enviamos nada por ninguna salida\n    return [null, null];\n}",
