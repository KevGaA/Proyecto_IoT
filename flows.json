        "func": "const miChatId = \"1007849868\";\n\n// Capturamos la hora local exacta\nlet fecha = new Date().toLocaleString(\"es-CL\", { timeZone: \"America/Santiago\" });\n\n// Construimos el mensaje de prueba cumpliendo la rúbrica\nlet textoAlerta = \"🚨 *SIMULACRO DE SISTEMA* 🚨\\n\\n\" +\n    \"Evento: Disparo manual desde Dashboard\\n\" +\n    \"Valor: Botón de Pánico\\n\" +\n    \"Timestamp: \" + fecha;\n\n// Formateamos el paquete exactamente como lo exige el nodo de Telegram\nmsg.payload = {\n    chatId: miChatId,\n    type: \"message\",\n    content: textoAlerta\n};\n\nreturn msg;",
